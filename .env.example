# Environment file template
# Copy this to .env and fill in actual values

# Environment
ENVIRONMENT=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rupiah_rates
DB_USER=postgres
DB_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rupiah_rates

# API Configuration
API_KEY=your_api_key_here
API_TIMEOUT=30
API_RETRIES=3

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Airflow
AIRFLOW_HOME=/app/airflow
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://postgres:postgres@localhost:5432/airflow

# dbt
DBT_PROFILES_DIR=./dbt
DBT_TARGET=dev
